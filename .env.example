# .env.example — Environment variables for both backend and frontend.

# ── Backend (Django) ───────────────────────────────────────────
# Set these in backend/.env or export them before running manage.py
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# ── Frontend (Next.js) ────────────────────────────────────────
# Set these in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000/api
